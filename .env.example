# Required: Discord webhook URL for posting notifications.
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your/webhook_url"

# Optional: Google Gemini API key and model for translation/headline generation.
# If GEMINI_API_KEY is empty, the app falls back to the free translation service.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Optional: target language code for the free translation fallback.
TARGET_LANGUAGE="ja"

# Optional: override curl binary paths when running outside the provided Docker image.
CURL_CHROME116_PATH="/usr/local/bin/curl_chrome116"
CURL_PATH="/usr/bin/curl"
